#! /usr/bin/env python3
# Standalone harness to verify interactive point dragging in kateri.
#
# Starts a unix-socket server, launches kateri, sends a synthetic (non-real) chart, then polls a control file
# for commands to forward (get_chart / get_moved_points / quit) and writes responses to stdout. This lets an
# operator drag points in the GUI between command issuances.
#
#   ./drag-test /tmp/k.sock /tmp/k.cmd
#   # then: echo get_moved_points > /tmp/k.cmd ; echo get_chart > /tmp/k.cmd ; echo quit > /tmp/k.cmd

import sys, os, json, asyncio, subprocess
from pathlib import Path

KATERI_EXE = Path(__file__).parent.joinpath("../build/macos/Build/Products/Release/kateri.app/Contents/MacOS/kateri").resolve()
CHART = Path(__file__).parent.joinpath("drag-test-chart.json")

try:
    import ae_backend.chart_v3 as cv3
    HAVE_AE = True
except ImportError:
    HAVE_AE = False
    print(">>> ae_backend not importable — RLAX will only fetch (no real relax). Run with python3.10 + PYTHONPATH=.../build.", file=sys.stderr, flush=True)

command_id = 0
writer_g = None
relax_pending = False

def send(data_code: bytes, data: bytes):
    writer_g.write(data_code)
    writer_g.write(len(data).to_bytes(4, byteorder=sys.byteorder))
    writer_g.write(data)
    if last := len(data) % 4:
        writer_g.write(b"\x00" * (4 - last))

def send_command(cmd: dict):
    global command_id
    command_id += 1
    send(b"COMD", json.dumps({**cmd, "_id": command_id}).encode("utf-8"))

async def read_payload(reader):
    payload_length = int.from_bytes(await reader.read(4), byteorder=sys.byteorder)
    data = b""
    while len(data) < payload_length:
        data += await reader.read(payload_length - len(data))
    if (pad := 4 - payload_length % 4) != 4:
        await reader.read(pad)
    return data

async def connected(reader, writer):
    global writer_g, relax_pending
    writer_g = writer
    cmd_file = Path(sys.argv[2])
    print(">>> connected", file=sys.stderr, flush=True)
    while (request := (await reader.read(4)).decode("utf8").strip()) not in ["", "QUIT"]:
        if request == "HELO":
            print(f">>> HELO; sending chart {CHART}", file=sys.stderr, flush=True)
            send(b"CHRT", CHART.read_bytes())
            await writer.drain()
            asyncio.create_task(poll_commands(cmd_file, writer))
        elif request == "RLAX":
            # Unsolicited notification from kateri's Relax button (bare 4-byte code, like HELO). This is what the
            # real ae side does: pull the edited chart, relax the whole map (every point free — NO pinning), and
            # push the relaxed chart back so kateri re-renders it. We fetch get_chart and relax its reply below.
            print(f">>> RLAX received from kateri — relaxing the whole map ({'ae_backend' if HAVE_AE else 'fetch-only, no ae_backend'})", flush=True)
            relax_pending = True
            send_command({"C": "get_moved_points"})  # informational only
            send_command({"C": "get_chart"})
            await writer.drain()
        elif request in ["CHRT", "JSON", "PDFB"]:
            data = await read_payload(reader)
            if request == "CHRT":
                if relax_pending and HAVE_AE:
                    relax_pending = False
                    try:
                        chart = cv3.chart_from_json(data)
                        proj = chart.projection(0)
                        npoints = chart.number_of_antigens() + chart.number_of_sera()
                        start = [list(proj.layout()[i]) if proj.layout()[i] is not None else None for i in range(npoints)]
                        before = proj.stress()
                        proj.relax()  # all points free to move; nothing pinned
                        end = [list(proj.layout()[i]) if proj.layout()[i] is not None else None for i in range(npoints)]
                        # The optimiser returns the layout in a freely chosen gauge (rotation/reflection/
                        # translation), so align the relaxed layout back onto the start with Procrustes/Kabsch
                        # before animating. THIS IS WHAT THE REAL ae SIDE MUST DO TO EACH STREAMED FRAME.
                        import numpy as np
                        idx = [i for i in range(npoints) if start[i] is not None and end[i] is not None]
                        if len(idx) >= 2:
                            A = np.array([start[i] for i in idx]); B = np.array([end[i] for i in idx])
                            cA, cB = A.mean(0), B.mean(0)
                            U, _, Vt = np.linalg.svd((B - cB).T @ (A - cA))
                            R = Vt.T @ U.T  # orthogonal, reflection allowed (maps may be reflected)
                            full = np.array([(e if e is not None else [0.0, 0.0]) for e in end])
                            full = (full - cB) @ R.T + cA
                            end = [list(full[i]) if end[i] is not None else None for i in range(npoints)]
                        # Stream LAYT frames so kateri animates the relax (last frame "final" commits the layout).
                        # NOTE: this interpolates start->relaxed; real per-iteration optimiser frames need
                        # ae_backend's IntermediateLayouts exposed to Python (C++ binding + rebuild).
                        FRAMES = 24
                        for f in range(1, FRAMES + 1):
                            t = f / FRAMES
                            frame = [[s[0] + (e[0] - s[0]) * t, s[1] + (e[1] - s[1]) * t] if (s and e) else None for s, e in zip(start, end)]
                            send(b"LAYT", json.dumps({"l": frame, "final": f == FRAMES}).encode())
                            await writer.drain()
                            await asyncio.sleep(0.03)
                        print(f"<<< relaxed, stress {before:.4f} -> {proj.stress():.4f}; streamed {FRAMES} frames (last=final)", flush=True)
                    except Exception as err:
                        print(f">> relax failed: {err}", file=sys.stderr, flush=True)
                else:
                    relax_pending = False
                    chart = json.loads(data)
                    layout = chart["c"]["P"][0]["l"]
                    print(f"<<< CHRT ({len(data)} bytes) layout:", flush=True)
                    for i, p in enumerate(layout):
                        print(f"      [{i}] {p}", flush=True)
            elif request == "JSON":
                print(f"<<< JSON {json.loads(data)}", flush=True)
            else:
                print(f"<<< PDFB {len(data)} bytes", flush=True)
        await writer.drain()
    print(">>> kateri quit", file=sys.stderr, flush=True)
    writer.close()
    asyncio.get_event_loop().stop()

async def poll_commands(cmd_file: Path, writer):
    if cmd_file.exists():
        cmd_file.unlink()
    while True:
        await asyncio.sleep(0.2)
        if cmd_file.exists():
            cmd = cmd_file.read_text().strip()
            cmd_file.unlink()
            print(f">>> command: {cmd}", file=sys.stderr, flush=True)
            payload = {"C": cmd}
            if cmd == "pdf":
                payload["width"] = 800.0
            send_command(payload)
            await writer.drain()

async def main():
    sock = sys.argv[1]
    if os.path.exists(sock):
        os.unlink(sock)
    server = await asyncio.start_unix_server(connected, sock)
    print(f">>> server on {sock}", file=sys.stderr, flush=True)
    kateri = await asyncio.create_subprocess_exec(str(KATERI_EXE), "--socket", sock)
    async with server:
        await server.serve_forever()

try:
    asyncio.run(main())
except (KeyboardInterrupt, RuntimeError):
    pass
